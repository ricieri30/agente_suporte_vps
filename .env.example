# VPS Guardian - Configurações

# Ambiente
NODE_ENV=production
PORT=3000

# Backup
BACKUP_DIR=/var/backups/vps-guardian
MAX_BACKUPS=6
BACKUP_SCHEDULE=0 1 * * *

# Webhooks (Alertas)
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_TYPE=slack

# Monitoramento
CPU_THRESHOLD=90
MEMORY_THRESHOLD=90
DISK_THRESHOLD=85
MONITORING_INTERVAL=30

# Frontend
REACT_APP_API_URL=http://localhost:3000/api
VITE_API_URL=http://localhost:3000/api
